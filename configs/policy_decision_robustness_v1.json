{
  "schema_version": "policy-decision-robustness-config/v1",
  "description": "Policy Decision Robustness v1 audit config. This consumes current-HEAD batch, stability, path-feedback, and sample-quality summaries to compare candidate ordering profiles only; it does not run PPO or change network/action-space behavior.",
  "legacy_profile_id": "legacy",
  "feedback_aware_profile_id": "feedback_aware",
  "sample_quality_aware_profile_id": "sample_quality_aware",
  "output_files": {
    "robustness_summary": "policy-decision-robustness-summary.json",
    "selection_comparison_summary": "policy-decision-selection-comparison-summary.json"
  },
  "validation": {
    "require_current_git_match": true,
    "fail_on_input_failure": true
  },
  "scoring": {
    "path_cost_normalizer": 100.0,
    "high_path_cost_threshold": 100.0,
    "utility_weight": 1.0,
    "path_cost_weight": 0.25,
    "risk_weight": 0.25,
    "unreachable_penalty": 1.0,
    "failure_penalty": 1.0,
    "replan_penalty": 0.5,
    "high_path_cost_penalty": 0.35,
    "iris_fallback_penalty": 0.1,
    "region_graph_fallback_penalty": 0.2,
    "region_graph_disconnected_penalty": 0.3,
    "open_grid_fallback_penalty": 2.0,
    "sample_quality_downweight_penalty": 0.5,
    "sample_quality_exclude_penalty": 2.0
  },
  "profiles": [
    {
      "id": "legacy",
      "description": "Legacy audit profile: rank candidates by original candidate utility/order only.",
      "use_path_feedback": false,
      "use_sample_quality": false
    },
    {
      "id": "feedback_aware",
      "description": "Feedback-aware audit profile: rank candidates with path cost, reachability, replan, IRIS, and region-graph diagnostics.",
      "use_path_feedback": true,
      "use_sample_quality": false
    },
    {
      "id": "sample_quality_aware",
      "description": "Sample-quality-aware audit profile: feedback-aware scoring plus sample-quality application profile action/weight penalties.",
      "use_path_feedback": true,
      "use_sample_quality": true,
      "sample_quality_source_profile_id": "soft_downweight_diagnostics"
    }
  ],
  "non_goals": [
    "no_ppo_main_path_change",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_gcs_graph_search",
    "no_gcs_trajectory_backend",
    "no_vehicle_motion_feasibility_solver",
    "no_ackermann_feasible_trajectory_claim",
    "iris_and_region_graph_are_diagnostics_only",
    "quasi_real_is_not_real_world_generalization_performance"
  ]
}
