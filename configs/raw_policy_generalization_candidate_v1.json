{
  "schema_version": "raw-policy-generalization-candidate-config/v1",
  "description": "Train an experimental raw-policy generalization candidate with TRAIN/dev raw-regression preferences and VAL-only seed selection.",
  "input_files": {
    "batch_summary": "batch-evaluation-summary.json",
    "anchor_candidate_summary": "anchor-projection-candidate-generation-summary.json",
    "planner_validated_mining_summary": "planner-validated-trainable-target-mining-summary.json",
    "rollout_episodes": "planner-validated-rollout-episodes.jsonl",
    "materialization_summary": "planner-validated-training-input-materialization-summary.json",
    "unified_policy_sample_registry": "unified-policy-sample-registry.jsonl",
    "unified_policy_sample_registry_summary": "unified-policy-sample-registry-summary.json",
    "hybrid_policy_training_dry_run_summary": "hybrid-policy-training-dry-run-summary.json",
    "raw_policy_regression_mining_summary": "raw-policy-generalization-training-raw-mining-summary.json",
    "raw_policy_regression_preference_samples": "raw-policy-generalization-training-preference-samples.jsonl"
  },
  "output_files": {
    "summary": "raw-policy-generalization-candidate-summary.json",
    "checkpoint": "experimental-hybrid-policy-candidate.pt",
    "checkpoint_metadata": "experimental-hybrid-policy-candidate-metadata.json",
    "training_samples": "raw-policy-generalization-training-preference-samples.jsonl",
    "training_mining_summary": "raw-policy-generalization-training-raw-mining-summary.json",
    "overfit_report": "raw-policy-generalization-overfit-report.json",
    "training_curves": "raw-policy-generalization-training-curves.json"
  },
  "source_preconditions": {
    "max_failed_count": 0,
    "max_fallback_or_open_grid_count": 0,
    "max_safety_regression_count": 0,
    "max_current_git_provenance_mismatch_count": 0,
    "max_git_provenance_mismatch_count": 0
  },
  "validation": {
    "expected_action_label_positive_count": 24,
    "max_invalid_action_mask_count": 0,
    "max_empty_action_mask_count": 0,
    "max_hard_positive_added_count": 0,
    "max_leaked_context_id_count": 0
  },
  "training": {
    "seeds": [0, 1, 2],
    "hidden_size": 16,
    "learning_rate": 0.003,
    "max_epochs": 80,
    "early_stopping_patience": 8,
    "weight_decay": 0.0001,
    "margin": 0.5,
    "action_label_loss_weight": 1.0,
    "preference_loss_weight": 1.0,
    "residual_negative_loss_weight": 1.0,
    "val_metric": "raw_policy_regression_count"
  },
  "checkpoint": {
    "experimental": true,
    "publishes_checkpoint": false,
    "replaces_default_policy": false
  },
  "evaluation": {
    "shadow_mode": true,
    "controlled_selection_mode": false,
    "hidden_size": 16,
    "max_path_cost_regression": 0.0,
    "max_risk_regression": 0.0
  },
  "val_evaluation": {
    "candidate_summary_schema_versions": [
      "controlled-hybrid-policy-training-candidate-summary/v1"
    ],
    "min_scenario_disjoint_context_count": 1,
    "require_context_id": true,
    "require_candidate_git_current_match": true,
    "allow_dirty_current_git_match": true,
    "max_invalid_action_mask_count": 0,
    "max_fallback_or_open_grid_count": 0,
    "max_safety_regression_count": 0,
    "max_contract_violation_count": 0,
    "max_path_cost_regression_count": 0,
    "max_risk_regression_count": 0,
    "max_source_selection_regression_count": 0,
    "max_regression_count": 0
  },
  "non_goals": [
    "no_formal_ppo_rollout",
    "no_production_checkpoint_publication",
    "no_default_policy_replacement",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_default_astar_change",
    "no_default_distance_contract_relaxation",
    "no_policy_performance_claim",
    "no_ackermann_feasible_trajectory_claim"
  ]
}
