{
  "schema_version": "quasi-real-map-domain-gap-evaluation-config/v1",
  "top_k": 3,
  "max_slices": 12,
  "planning_backend": "channel_aware_astar",
  "validation": {
    "min_slice_count": 12,
    "min_roi_group_count": 4,
    "max_path_cost_mean_delta_abs": 1000.0
  },
  "scope_guards": [
    "no_ppo_update",
    "no_checkpoint_publication",
    "no_default_policy_replacement",
    "no_network_or_action_space_change",
    "no_default_astar_change",
    "no_distance_contract_relaxation",
    "no_ackermann_feasible_trajectory_claim"
  ]
}
