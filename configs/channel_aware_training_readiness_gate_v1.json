{
  "schema_version": "channel-aware-training-readiness-gate-config/v1",
  "description": "Channel-Aware Training Readiness Gate v1. This consumes channel-aware application smoke evidence and emits a pre-training readiness audit only; it does not train PPO, change default A*, or claim vehicle-motion feasibility.",
  "output_files": {
    "training_readiness_summary": "channel-aware-training-readiness-summary.json"
  },
  "validation": {
    "require_current_git_match": true,
    "fail_on_input_failure": true
  },
  "readiness_thresholds": {
    "min_positive_evidence_count": 1,
    "min_positive_evidence_rate": 0.25,
    "max_excluded_candidate_rate_for_policy_smoke": 0.75,
    "block_excluded_candidate_rate": 0.9,
    "require_selected_candidate_change_for_ready": true
  },
  "non_goals": [
    "no_ppo_training",
    "no_ppo_main_path_change",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_default_astar_change",
    "no_path_planner_route_contract_change",
    "no_model_explorer_contract_change",
    "no_path_planner_sidecar_contract_change",
    "no_gcs_graph_search",
    "no_gcs_control_point_candidate_as_default_execution_trajectory",
    "no_ackermann_feasible_trajectory_claim",
    "no_real_world_performance_claim",
    "no_c_space_iris",
    "no_iris_np",
    "no_iris_np2",
    "no_iris_zo"
  ]
}
