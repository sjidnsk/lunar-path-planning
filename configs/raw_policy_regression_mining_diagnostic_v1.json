{
  "schema_version": "raw-policy-regression-mining-config/v1",
  "description": "Mine raw-policy regressions as diagnostic-only records for VAL/TEST without adding preference samples.",
  "input_files": {
    "source_batch_summary": "batch-evaluation-summary.json",
    "rollout_summary": "scenario-disjoint-policy-rollout-evaluation-summary.json",
    "rollout_decisions": "scenario-disjoint-policy-rollout-decisions.jsonl"
  },
  "output_files": {
    "summary": "raw-policy-regression-mining-summary.json",
    "samples": "raw-policy-regression-preference-samples.jsonl",
    "diagnostics": "raw-policy-regression-diagnostics.jsonl",
    "exclusion_report": "raw-policy-regression-exclusion-report.json"
  },
  "sample": {
    "mode": "diagnostic_only",
    "sample_weight": 0.0
  },
  "validation": {
    "expected_raw_policy_regression_input_count": null,
    "min_raw_policy_regression_preference_pair_count": 0,
    "max_hard_positive_added_count": 0,
    "require_source_batch_passed": true,
    "require_rollout_summary_passed": true,
    "require_current_git_match": true,
    "allow_dirty_current_git_match": true
  },
  "non_goals": [
    "no_hard_positive_addition",
    "no_training_sample_output_for_eval_split",
    "no_formal_ppo_rollout",
    "no_checkpoint_publication",
    "no_default_policy_replacement",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_default_distance_contract_relaxation",
    "no_ackermann_feasible_trajectory_claim"
  ]
}
