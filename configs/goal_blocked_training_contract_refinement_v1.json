{
  "schema_version": "goal-blocked-training-contract-refinement-config/v1",
  "description": "Goal-Blocked Training Contract Refinement v1. This audit-only stage classifies goal_blocked and excluded candidates before any policy training dry run.",
  "output_files": {
    "goal_blocked_training_contract_refinement_summary": "goal-blocked-training-contract-refinement-summary.json"
  },
  "validation": {
    "require_current_git_match": true,
    "fail_on_input_failure": true
  },
  "classification": {
    "require_finite_comparison_for_negative_evidence": true
  },
  "non_goals": [
    "no_ppo_training",
    "no_large_scale_training",
    "no_ppo_main_path_change",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_default_astar_change",
    "no_model_explorer_contract_change",
    "no_path_planner_route_stable_field_semantics_change",
    "no_path_planner_sidecar_stable_field_semantics_change",
    "no_ackermann_feasible_trajectory_claim",
    "no_real_world_performance_claim"
  ]
}
