{
  "schema_version": "quasi-real-guarded-ppo-evidence-freeze-config/v1",
  "description": "Freeze quasi-real guarded PPO rollout pilot evidence into a reproducible, auditable manifest without running a new PPO update or changing gates.",
  "default_paths": {
    "pilot_root": "outputs/path_feedback_batch_quasi_real_guarded_ppo_rollout_pilot_v1",
    "batch_root": "outputs/path_feedback_batch_guarded_ppo_rollout_clean_src_v1",
    "update_root": "outputs/path_feedback_batch_return_aligned_guarded_ppo_update_smoke_v1",
    "output_root": "outputs/path_feedback_batch_quasi_real_guarded_ppo_evidence_freeze_v1"
  },
  "readiness": {
    "config": "configs/policy_training_readiness_review_v1.json",
    "expected_status": "quasi_real_guarded_ppo_rollout_pilot_evaluated"
  },
  "required_artifacts": [
    "quasi-real-guarded-ppo-rollout-pilot-summary.json",
    "quasi-real-guarded-ppo-rollout-episodes.jsonl",
    "quasi-real-guarded-ppo-rollout-steps.jsonl",
    "quasi-real-guarded-ppo-rollout-rejection-report.json",
    "quasi-real-guarded-ppo-rollout-reward-audit.json",
    "quasi_real_collector_replay/ppo-rollout-collector-summary.json",
    "post_update_long_horizon/long-horizon-teacher-skill-contract-summary.json",
    "return-aligned-guarded-ppo-update-smoke-summary.json",
    "quasi-real-guarded-ppo-readiness-validate-only.json"
  ],
  "output_files": {
    "summary": "quasi-real-guarded-ppo-evidence-freeze-summary.json",
    "manifest": "quasi-real-guarded-ppo-evidence-manifest.json",
    "readiness_validate_only": "quasi-real-guarded-ppo-readiness-validate-only.json",
    "report": "quasi-real-guarded-ppo-evidence-freeze-report.md"
  },
  "validation": {
    "min_episode_count": 36,
    "min_step_count": 108,
    "min_ppo_trainable_transition_count": 24,
    "expected_ppo_trainable_transition_count": 36,
    "expected_diagnostic_transition_count": 72,
    "min_teacher_agreement_rate": 0.9,
    "min_collector_replay_trainable_transition_count": 24,
    "expected_long_horizon_verdict": "long_horizon_teacher_skill_contract_aligned"
  },
  "non_goals": [
    "does_not_start_new_ppo_update",
    "does_not_expand_batch",
    "does_not_enter_formal_training",
    "does_not_publish_checkpoint",
    "does_not_replace_default_policy",
    "does_not_modify_network",
    "does_not_modify_action_space",
    "does_not_modify_default_astar",
    "does_not_relax_distance_path_risk_or_source_selection_gates",
    "does_not_claim_ackermann_feasible_trajectory",
    "does_not_treat_iris_gcs_or_path_planner_diagnostics_as_training_release",
    "does_not_claim_policy_performance"
  ]
}
