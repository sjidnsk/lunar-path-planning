{
  "schema_version": "quasi-real-guarded-ppo-stability-replay-config/v1",
  "description": "Replay the passed quasi-real guarded PPO rollout pilot multiple times against frozen evidence and refine the pre-formal-training acceptance contract without running a new PPO update.",
  "default_paths": {
    "freeze_root": "outputs/path_feedback_batch_quasi_real_guarded_ppo_evidence_freeze_v1",
    "batch_root": "outputs/path_feedback_batch_guarded_ppo_rollout_clean_src_v1",
    "output_root": "outputs/path_feedback_batch_quasi_real_guarded_ppo_stability_replay_v1",
    "pilot_config": "configs/quasi_real_guarded_ppo_rollout_pilot_v1.json"
  },
  "replay": {
    "replay_count": 3
  },
  "readiness": {
    "config": "configs/policy_training_readiness_review_v1.json",
    "expected_status": "quasi_real_guarded_ppo_stability_replay_evaluated"
  },
  "validation": {
    "expected_episode_count": 36,
    "expected_step_count": 108,
    "min_ppo_trainable_transition_count": 24,
    "expected_ppo_trainable_transition_count": 36,
    "expected_diagnostic_transition_count": 72,
    "min_teacher_agreement_rate": 0.9,
    "expected_long_horizon_verdict": "long_horizon_teacher_skill_contract_aligned"
  },
  "output_files": {
    "summary": "quasi-real-guarded-ppo-stability-replay-summary.json",
    "comparison": "stability-replay-comparison.jsonl",
    "acceptance_contract": "acceptance-contract-refinement.json",
    "progress_events": "stability-replay-progress-events.jsonl",
    "readiness_validate_only": "quasi-real-guarded-ppo-stability-readiness-validate-only.json",
    "report": "stability-replay-report.md"
  },
  "non_goals": [
    "does_not_start_new_ppo_update",
    "does_not_expand_batch",
    "does_not_enter_formal_training",
    "does_not_publish_checkpoint",
    "does_not_replace_default_policy",
    "does_not_modify_network",
    "does_not_modify_action_space",
    "does_not_modify_default_astar",
    "does_not_relax_distance_path_risk_or_source_selection_gates",
    "does_not_claim_ackermann_feasible_trajectory",
    "does_not_treat_iris_gcs_or_path_planner_diagnostics_as_training_release",
    "does_not_claim_policy_performance"
  ]
}
