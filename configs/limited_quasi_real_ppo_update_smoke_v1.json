{
  "schema_version": "limited-quasi-real-ppo-update-smoke-config/v1",
  "description": "Limited Quasi-Real PPO Update Smoke v1. Run one tiny local PPO update from quasi-real collector trainable transitions, then re-run generated and quasi-real gates.",
  "input_files": {
    "rollout_episodes": "ppo-rollout-episodes.jsonl",
    "rollout_transitions": "ppo-rollout-transitions.jsonl",
    "collector_summary": "ppo-rollout-collector-summary.json",
    "base_checkpoint": "experimental-hybrid-policy-candidate.pt",
    "base_checkpoint_metadata": "experimental-hybrid-policy-candidate-metadata.json",
    "base_candidate_summary": "raw-policy-generalization-candidate-summary.json"
  },
  "output_files": {
    "summary": "limited-quasi-real-ppo-update-smoke-summary.json",
    "update_summary": "limited-ppo-update-smoke-summary.json",
    "training_curves": "limited-ppo-update-training-curves.json",
    "diagnostics": "limited-ppo-update-diagnostics.json",
    "checkpoint": "experimental-hybrid-policy-candidate.pt",
    "checkpoint_metadata": "experimental-hybrid-policy-candidate-metadata.json",
    "candidate_summary": "raw-policy-generalization-candidate-summary.json"
  },
  "trainable_filter": {
    "splits": [
      "train"
    ],
    "controlled_choice_sources": [
      "policy_teacher_aligned",
      "policy_safe_disagreement"
    ],
    "require_empty_gate_reason_codes": true
  },
  "training": {
    "device": "cpu",
    "seed": 0,
    "epochs": 1,
    "learning_rate": 0.00001,
    "clip_ratio": 0.2,
    "discount_factor": 0.99,
    "max_grad_norm": 1.0,
    "hidden_size": 16
  },
  "validation": {
    "expected_input_ppo_trainable_transition_count": 36,
    "min_optimizer_train_transition_count": 24,
    "max_old_log_prob_abs_error": 0.0001,
    "max_old_value_abs_error": 0.0001,
    "max_approx_kl": 0.25,
    "max_grad_norm_after_clip": 1.0,
    "min_post_update_ppo_trainable_transition_count": 24,
    "min_post_update_teacher_agreement_rate": 0.9
  },
  "evaluation": {
    "hidden_size": 16
  },
  "post_update_gates": {
    "enabled": true,
    "generated": {
      "raw_baseline_candidate_root": "outputs/path_feedback_batch_sequential_multi_step_opportunity_baseline_candidate_v1",
      "dev_root": "outputs/path_feedback_batch_sequential_multi_step_opportunity_dev_v1",
      "val_root": "outputs/path_feedback_batch_sequential_multi_step_opportunity_val_v1",
      "test_root": "outputs/path_feedback_batch_sequential_multi_step_opportunity_test_v1",
      "raw_generalization_config": "configs/raw_policy_generalization_evaluation_v1.json",
      "sequential_config": "configs/policy_gated_sequential_multi_step_opportunity_rollout_v1.json",
      "collector_config": "configs/ppo_rollout_collector_dry_run_v1.json",
      "sequential_root": "post_update_generated_sequential",
      "collector_root": "post_update_generated_collector"
    },
    "quasi_real": {
      "teacher_following_config": "configs/quasi_real_guarded_teacher_following_pilot_v1.json",
      "collector_config": "configs/quasi_real_ppo_collector_dry_run_v1.json",
      "teacher_following_root": "post_update_quasi_real_teacher_following",
      "collector_root": "post_update_quasi_real_collector"
    }
  },
  "non_goals": [
    "no_formal_ppo_rollout",
    "no_checkpoint_publication",
    "no_default_policy_replacement",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_default_astar_change",
    "no_distance_contract_relaxation",
    "no_path_risk_source_selection_gate_relaxation",
    "no_ackermann_feasible_trajectory_claim",
    "no_iris_gcs_training_release_claim",
    "no_policy_performance_claim",
    "no_formal_training_ready_claim"
  ]
}
