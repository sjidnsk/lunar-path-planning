{
  "schema_version": "planner-validated-training-input-materialization-config/v1",
  "description": "Materialize planner-validated trainable anchor-projection targets into the existing RolloutEpisode/RolloutTransition training input contract.",
  "input_files": {
    "planner_validated_trainable_target_mining_summary": "planner-validated-trainable-target-mining-summary.json",
    "anchor_projection_candidate_generation_summary": "anchor-projection-candidate-generation-summary.json"
  },
  "output_files": {
    "rollout_episodes": "planner-validated-rollout-episodes.jsonl",
    "summary": "planner-validated-training-input-materialization-summary.json",
    "exclusion_report": "planner-validated-training-exclusion-report.json"
  },
  "validation": {
    "fail_on_input_failure": true,
    "fail_on_provenance_mismatch": true,
