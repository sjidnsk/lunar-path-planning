{
  "schema_version": "sequential-evidence-consistency-config/v1",
  "description": "Check that sequential final rollout and readiness evidence are consistent before PPO collector dry-run.",
  "diagnosis_role": "preflight_only",
  "input_files": {
    "rollout_summary": "policy-gated-sequential-canary-rollout-summary.json",
    "diagnosis_summary": "sequential-multi-step-opportunity-diagnosis-summary.json"
  },
