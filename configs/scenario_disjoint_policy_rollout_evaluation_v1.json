{
  "schema_version": "scenario-disjoint-policy-rollout-evaluation-config/v1",
  "description": "Shadow-first controlled rollout evaluation for a local experimental hybrid policy candidate on scenario-disjoint holdout contexts.",
  "input_files": {
    "source_batch_summary": "batch-evaluation-summary.json",
    "holdout_batch_summary": "batch-evaluation-summary.json",
    "fresh_holdout_summary": "fresh-holdout-policy-candidate-evaluation-summary.json",
    "candidate_summary": "controlled-hybrid-policy-training-candidate-summary.json",
    "checkpoint": "experimental-hybrid-policy-candidate.pt",
    "checkpoint_metadata": "experimental-hybrid-policy-candidate-metadata.json"
  },
  "output_files": {
    "decisions": "scenario-disjoint-policy-rollout-decisions.jsonl",
    "regression_report": "scenario-disjoint-policy-rollout-regression-report.json",
    "summary": "scenario-disjoint-policy-rollout-evaluation-summary.json"
  },
  "evaluation": {
    "shadow_mode": true,
    "controlled_selection_mode": false,
    "hidden_size": 16,
    "max_path_cost_regression": 0.0,
    "max_risk_regression": 0.0
  },
  "validation": {
    "min_scenario_disjoint_context_count": 1,
    "require_context_id": true,
    "require_candidate_git_current_match": true,
    "max_invalid_action_mask_count": 0,
    "max_fallback_or_open_grid_count": 0,
    "max_safety_regression_count": 0,
    "max_contract_violation_count": 0,
    "max_path_cost_regression_count": 0,
    "max_risk_regression_count": 0,
    "max_source_selection_regression_count": 0,
    "max_regression_count": 0
  },
  "non_goals": [
    "no_formal_ppo_rollout",
    "no_production_checkpoint_publication",
    "no_default_policy_replacement",
    "no_network_architecture_change",
    "no_action_space_change",
    "no_default_astar_change",
    "no_default_distance_contract_relaxation",
    "no_policy_performance_claim",
    "no_ackermann_feasible_trajectory_claim"
  ]
}
